{
  "name": "@bentham/constants",
  "version": "1.5.0",
  "description": "Shared constants and utilities for Bentham services",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    },
    "./logger": {
      "types": "./dist/src/logger/index.d.ts",
      "default": "./dist/src/logger/index.js"
    },
    "./hmac": {
      "types": "./dist/src/hmac/index.d.ts",
      "default": "./dist/src/hmac/index.js"
    },
    "./config": {
      "types": "./dist/src/config/index.d.ts",
      "default": "./dist/src/config/index.js"
    },
    "./env": {
      "types": "./dist/src/env/index.d.ts",
      "default": "./dist/src/env/index.js"
    },
    "./middleware": {
      "types": "./dist/src/middleware/index.d.ts",
      "default": "./dist/src/middleware/index.js"
    },
    "./fetch": {
      "types": "./dist/src/fetch/index.d.ts",
      "default": "./dist/src/fetch/index.js"
    },
    "./incorporation": {
      "types": "./dist/src/incorporation/index.d.ts",
      "default": "./dist/src/incorporation/index.js"
    },
    "./distributed-lock": {
      "types": "./dist/src/distributed-lock/index.d.ts",
      "default": "./dist/src/distributed-lock/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "tsconfig.json"
  ],
  "scripts": {
    "build": "tsc",
    "prepare": "npm run build",
    "test": "jest",
    "prepublishOnly": "npm run build"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BenthamTech/bentham-constants.git"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@google-cloud/firestore": "7.11.0",
    "pino": "9.6.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/node": "22.10.0",
    "jest": "29.7.0",
    "ts-jest": "29.2.5",
    "typescript": "5.7.3"
  }
}
